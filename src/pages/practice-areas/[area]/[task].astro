---
import Layout from "@/layouts/Layout.astro";
import BreadcrumbNav from "@/components/BreadcrumbNav.astro";
import RubricList from "@/components/RubricList.tsx";
import index from "@/data/index.json";
import categories from "@/data/categories.json";
import type { SearchIndexEntry, PracticeAreaSummary, Task } from "@/lib/types";
import { WORK_TYPE_LABEL, WORK_TYPE_BLURB } from "@/lib/practice-areas";

const taskModules = import.meta.glob<{ default: Task }>(
  "/src/data/tasks/*.json",
  { eager: true },
);

function loadTask(id: string): Task {
  const key = `/src/data/tasks/${id}.json`;
  const mod = taskModules[key];
  if (!mod) throw new Error(`Task not found: ${id}`);
  return mod.default;
}

export function getStaticPaths() {
  const all = index as SearchIndexEntry[];
  return all.map((t) => {
    const taskParam = t.scenarioId
      ? `${t.taskSlug}--${t.scenarioId}`
      : t.taskSlug;
    return { params: { area: t.practiceArea, task: taskParam } };
  });
}

const { area: areaParam, task: taskParam } = Astro.params as {
  area: string;
  task: string;
};
const taskId = `${areaParam}--${taskParam}`;
const task = loadTask(taskId);
const cats = categories as PracticeAreaSummary[];
const area = cats.find((c) => c.slug === task.practiceArea);

function formatBytes(n: number): string {
  if (n < 1024) return `${n} B`;
  if (n < 1024 * 1024) return `${(n / 1024).toFixed(1)} KB`;
  return `${(n / (1024 * 1024)).toFixed(1)} MB`;
}

const extLabel: Record<string, string> = {
  ".docx": "DOCX",
  ".xlsx": "XLSX",
  ".pdf": "PDF",
  ".eml": "EML",
  ".txt": "TXT",
  ".md": "MD",
  ".pptx": "PPTX",
};

const extColors: Record<string, string> = {
  ".docx": "bg-accent-50 text-accent-700",
  ".xlsx": "bg-emerald-50 text-emerald-700",
  ".pdf": "bg-rose-50 text-rose-700",
  ".eml": "bg-amber-50 text-amber-700",
  ".txt": "bg-ink-100 text-ink-700",
  ".md": "bg-ink-100 text-ink-700",
  ".pptx": "bg-orange-50 text-orange-700",
};

const wtPillColors: Record<string, string> = {
  analyze: "bg-accent-100 text-accent-700",
  draft: "bg-accent-50 text-accent-600",
  review: "bg-ink-100 text-ink-700",
  research: "bg-ink-50 text-ink-700",
};
---

<Layout title={task.title} description={task.instructions.slice(0, 180)}>
  <section class="max-w-5xl mx-auto px-6 pt-8 pb-16">
    <BreadcrumbNav
      crumbs={[
        { label: "Home", href: "/" },
        { label: "Practice areas", href: "/practice-areas" },
        { label: area?.name ?? task.practiceArea, href: `/practice-areas/${task.practiceArea}` },
        { label: task.taskSlug },
      ]}
    />

    <div class="mt-4 flex items-center gap-2 flex-wrap">
      <span class={`text-[11.5px] font-medium px-2 py-0.5 rounded ${wtPillColors[task.workType] ?? "bg-ink-100"}`}>
        {WORK_TYPE_LABEL[task.workType]}
      </span>
      {task.scenarioId && (
        <span class="text-[11.5px] text-ink-500 font-mono">{task.scenarioId}</span>
      )}
      <a
        href={task.githubUrl}
        target="_blank"
        rel="noopener"
        class="ml-auto text-[12px] font-medium text-ink-700 hover:text-ink-900 inline-flex items-center gap-1.5 border border-ink-200 hover:border-ink-400 bg-white rounded-md px-2.5 py-1 transition"
      >
        <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8a8 8 0 005.47 7.59c.4.07.55-.17.55-.38v-1.4c-2.22.48-2.69-1.07-2.69-1.07-.36-.92-.89-1.17-.89-1.17-.73-.5.05-.49.05-.49.81.06 1.23.83 1.23.83.72 1.23 1.88.87 2.34.67.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.03 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.28.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48v2.2c0 .21.15.46.55.38A8 8 0 0016 8c0-4.42-3.58-8-8-8z"></path>
        </svg>
        View source
        <span aria-hidden>↗</span>
      </a>
    </div>

    <h1 class="mt-3 font-display text-3xl md:text-[34px] font-semibold tracking-tight leading-[1.15] text-ink-900">
      {task.title}
    </h1>

    {task.tags.length > 0 && (
      <div class="mt-4 flex flex-wrap gap-1.5">
        {task.tags.map((tag) => (
          <span class="text-[11.5px] text-ink-600 px-2 py-1 rounded bg-ink-50 border border-ink-100">{tag}</span>
        ))}
      </div>
    )}

    <section class="mt-10">
      <h2 class="font-display text-[15px] font-semibold uppercase tracking-wider text-ink-500 mb-3">Instructions</h2>
      <div class="border border-[var(--rule)] bg-white rounded-lg p-5 text-[14.5px] leading-relaxed text-ink-800 whitespace-pre-wrap">
        {task.instructions}
      </div>
      <p class="mt-2 text-[12px] text-ink-500">
        Work type: <span class="text-ink-700">{WORK_TYPE_LABEL[task.workType]}</span> — {WORK_TYPE_BLURB[task.workType]}
      </p>
    </section>

    {task.deliverables.length > 0 && (
      <section class="mt-10">
        <h2 class="font-display text-[15px] font-semibold uppercase tracking-wider text-ink-500 mb-3">
          Deliverables <span class="text-ink-400 font-mono normal-case">({task.deliverables.length})</span>
        </h2>
        <ul class="flex flex-wrap gap-2">
          {task.deliverables.map((d) => (
            <li class="border border-[var(--rule)] bg-white rounded-md px-3 py-2 text-[13px] font-mono text-ink-800">
              {d.filename}
            </li>
          ))}
        </ul>
      </section>
    )}

    <section class="mt-10">
      <h2 class="font-display text-[15px] font-semibold uppercase tracking-wider text-ink-500 mb-3">
        Rubric <span class="text-ink-400 font-mono normal-case">({task.criteria.length})</span>
      </h2>
      <p class="text-[13px] text-ink-500 mb-4 max-w-2xl">
        Each criterion is judged independently as pass or fail. The task scores 1.0 only if every criterion passes.
      </p>
      <RubricList
        client:load
        criteria={task.criteria}
        deliverableFilenames={task.deliverables.map((d) => d.filename)}
      />
    </section>

    <section class="mt-10">
      <h2 class="font-display text-[15px] font-semibold uppercase tracking-wider text-ink-500 mb-3">
        Reference documents <span class="text-ink-400 font-mono normal-case">({task.documents.length})</span>
      </h2>
      {task.documents.length === 0 ? (
        <p class="text-[13px] text-ink-500">No reference documents attached.</p>
      ) : (
        <ul class="border border-[var(--rule)] rounded-lg bg-white divide-y divide-ink-100 overflow-hidden">
          {task.documents.map((doc) => (
            <li class="px-4 py-3 hover:bg-ink-50/40 transition">
              <div class="flex items-start gap-3">
                <span class={`text-[10.5px] font-mono font-medium px-1.5 py-0.5 rounded mt-[3px] shrink-0 ${extColors[doc.ext.toLowerCase()] ?? "bg-ink-100 text-ink-700"}`}>
                  {extLabel[doc.ext.toLowerCase()] ?? doc.ext.replace(".", "").toUpperCase()}
                </span>
                <div class="flex-1 min-w-0">
                  <div class="font-mono text-[12.5px] text-ink-800 break-all">{doc.name}</div>
                  {doc.snippet && (
                    <p class="mt-1.5 text-[12.5px] text-ink-600 leading-snug line-clamp-2">{doc.snippet}</p>
                  )}
                </div>
                <div class="text-right shrink-0 flex flex-col items-end gap-1.5">
                  <span class="font-mono text-[11px] text-ink-400 tabular-nums">{formatBytes(doc.sizeBytes)}</span>
                  <a
                    href={doc.githubUrl}
                    target="_blank"
                    rel="noopener"
                    class="text-[12px] text-ink-600 hover:text-ink-900 inline-flex items-center gap-1"
                  >
                    Open
                    <span aria-hidden>↗</span>
                  </a>
                </div>
              </div>
            </li>
          ))}
        </ul>
      )}
      <p class="mt-3 text-[12px] text-ink-500">
        Each document opens on GitHub, which renders .docx, .xlsx, and .pdf inline. Hosted in the upstream <a class="underline decoration-ink-300 hover:decoration-accent-500" href={task.githubUrl} target="_blank" rel="noopener">harvey-labs</a> repository.
      </p>
    </section>
  </section>
</Layout>
