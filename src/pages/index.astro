---
import Layout from "@/layouts/Layout.astro";
import PracticeAreaCard from "@/components/PracticeAreaCard.astro";
import summary from "@/data/summary.json";
import categories from "@/data/categories.json";
import type { PracticeAreaSummary } from "@/lib/types";

const areas = categories as PracticeAreaSummary[];
const topAreas = [...areas].sort((a, b) => b.taskCount - a.taskCount);
---

<Layout title="Legal Benchmarks Explorer">
  <section class="border-b border-[var(--rule)]">
    <div class="max-w-7xl mx-auto px-6 pt-14 pb-12">
      <p class="text-[12px] uppercase tracking-[0.18em] text-ink-500 font-medium">Harvey AI Legal Agent Benchmark</p>
      <h1 class="mt-3 font-display text-4xl md:text-5xl font-semibold tracking-tight leading-[1.05] text-ink-900 max-w-3xl">
        A concrete look at where legal AI is heading.
      </h1>
      <p class="mt-5 text-[15.5px] text-ink-600 leading-relaxed max-w-2xl">
        Harvey's open benchmark catalogs what AI agents are being measured against — drafting, reviewing, researching, analyzing. Pick a practice area to see the prompts and rubrics, or pull up a random task.
      </p>
      <div class="mt-7 flex flex-wrap gap-3">
        <a href="/practice-areas" class="inline-flex items-center gap-2 bg-ink-900 text-white text-[13px] font-medium px-4 py-2 rounded-md hover:bg-ink-700 transition">
          Browse practice areas
          <span aria-hidden>→</span>
        </a>
        <button id="random-task" type="button" class="inline-flex items-center gap-2 border border-ink-200 bg-white text-[13px] font-medium px-4 py-2 rounded-md hover:border-ink-400 transition disabled:opacity-60 disabled:cursor-not-allowed">
          Pull up a random task
          <span aria-hidden>→</span>
        </button>
      </div>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-6 py-12">
    <div class="flex items-baseline justify-between mb-5 gap-4">
      <div>
        <h2 class="font-display text-[22px] font-semibold tracking-tight text-ink-900">Largest practice areas</h2>
        <p class="mt-1 text-[12.5px] text-ink-500">Top 9 of {summary.totalPracticeAreas}, ranked by number of tasks.</p>
      </div>
      <a href="/practice-areas" class="text-[13px] text-ink-600 hover:text-ink-900 underline decoration-ink-300 shrink-0">View all {summary.totalPracticeAreas} →</a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
      {topAreas.slice(0, 9).map((area) => (
        <PracticeAreaCard area={area} />
      ))}
    </div>
  </section>
</Layout>

<script is:inline>
  document.getElementById("random-task")?.addEventListener("click", async (e) => {
    const btn = e.currentTarget;
    btn.setAttribute("disabled", "");
    try {
      const r = await fetch("/data/index.json");
      const entries = await r.json();
      const pick = entries[Math.floor(Math.random() * entries.length)];
      const slug = pick.scenarioId ? `${pick.taskSlug}--${pick.scenarioId}` : pick.taskSlug;
      window.location.href = `/practice-areas/${pick.practiceArea}/${slug}`;
    } catch {
      btn.removeAttribute("disabled");
    }
  });
</script>
