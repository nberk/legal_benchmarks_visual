---
import SearchBox from "./SearchBox.tsx";
const path = Astro.url.pathname;
function isActive(prefix: string) {
  if (prefix === "/") return path === "/";
  return path.startsWith(prefix);
}
---

<header class="border-b border-[var(--rule)] bg-[var(--bg)]/80 backdrop-blur sticky top-0 z-30">
  <div class="max-w-7xl mx-auto px-6 h-14 flex items-center gap-4">
    <a href="/" class="flex items-center gap-2.5 group shrink-0">
      <span class="inline-block w-6 h-6 rounded-sm bg-ink-900 text-bg flex items-center justify-center font-display font-semibold text-[13px] text-white">LB</span>
      <span class="font-display text-[15px] font-semibold tracking-tight hidden sm:inline">Legal Benchmarks</span>
    </a>
    <nav class="hidden md:flex items-center gap-1 text-[13px]">
      <a
        href="/practice-areas"
        class={`px-3 py-1.5 rounded-md transition hover:bg-ink-100 ${isActive("/practice-areas") ? "text-ink-900 bg-ink-100" : "text-ink-600"}`}
      >
        Practice areas
      </a>
      <a
        href="/biglaw-bench"
        class={`px-3 py-1.5 rounded-md transition hover:bg-ink-100 ${isActive("/biglaw-bench") ? "text-ink-900 bg-ink-100" : "text-ink-600"}`}
      >
        BigLawBench
      </a>
      <a
        href="/about"
        class={`px-3 py-1.5 rounded-md transition hover:bg-ink-100 ${isActive("/about") ? "text-ink-900 bg-ink-100" : "text-ink-600"}`}
      >
        About
      </a>
    </nav>
    <div class="flex-1 flex justify-end">
      <SearchBox client:load />
    </div>
    <a
      href="https://github.com/harveyai/harvey-labs"
      target="_blank"
      rel="noopener"
      class="text-[12px] text-ink-500 hover:text-ink-900 hidden lg:inline-flex items-center gap-1.5 shrink-0"
    >
      <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
        <path d="M8 0C3.58 0 0 3.58 0 8a8 8 0 005.47 7.59c.4.07.55-.17.55-.38v-1.4c-2.22.48-2.69-1.07-2.69-1.07-.36-.92-.89-1.17-.89-1.17-.73-.5.05-.49.05-.49.81.06 1.23.83 1.23.83.72 1.23 1.88.87 2.34.67.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.03 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.28.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48v2.2c0 .21.15.46.55.38A8 8 0 0016 8c0-4.42-3.58-8-8-8z"></path>
      </svg>
      harveyai/harvey-labs
    </a>
    <a
      href="https://nickberkconsulting.com"
      target="_blank"
      rel="noopener"
      class="text-[12px] text-ink-500 hover:text-ink-900 hidden lg:inline-flex items-center shrink-0"
    >
      Built by Nick Berk
    </a>
  </div>
</header>
